# Enable Basic Auth for /admin/ in the API container
# Copy this file to admin-auth.conf (same directory) to enable, and ensure
# you mount a htpasswd file at /etc/nginx/.htpasswd-boxion.
# Example to create htpasswd (locally):
#   docker run --rm httpd:2-alpine htpasswd -nbB admin 'yourpassword' > data/htpasswd-boxion

auth_basic "Restricted";
auth_basic_user_file /etc/nginx/.htpasswd-boxion;
